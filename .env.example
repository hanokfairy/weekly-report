# 네이버 검색 API (개발자센터 애플리케이션 등록 후 발급)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# GA4 서비스 계정 키 파일 경로 (Google Cloud Console에서 발급받은 JSON)
GA4_CREDENTIALS_PATH=./config/ga4-service-account.json

# 슬랙 봇 토큰 (xoxb-로 시작, files:write / chat:write 권한 필요)
SLACK_BOT_TOKEN=

# (선택) 스마트플레이스 스크래핑 전 ezVPN 연결 여부를 확인하기 위한 예상 공인 IP 앞자리
# 비워두면 이 안전장치를 건너뜁니다. 예: EXPECTED_VPN_IP_PREFIX=123.45.
EXPECTED_VPN_IP_PREFIX=
